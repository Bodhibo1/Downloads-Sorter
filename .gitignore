# Ignore Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environment folders
venv/
env/
.venv/

# Ignore PyInstaller build folders
build/
dist/
*.spec

# Ignore executables
*.exe

# Ignore system files
.DS_Store
Thumbs.db

# Ignore logs
*.log

# Optional: ignore IDE/editor files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project